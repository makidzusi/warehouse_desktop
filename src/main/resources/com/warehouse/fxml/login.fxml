<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.openjfx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.warehouse.controller.LoginController"
           styleClass="login-root">

    <VBox alignment="CENTER" spacing="0" maxWidth="400" maxHeight="500" styleClass="login-card">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <Label text="СКЛАД" styleClass="login-logo"/>
        <Label text="Система управления складом" styleClass="login-subtitle"/>

        <VBox spacing="16" style="-fx-padding: 30 0 0 0;">
            <VBox spacing="6">
                <Label text="Логин" styleClass="field-label"/>
                <TextField fx:id="usernameField" promptText="Введите логин" styleClass="login-field"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Пароль" styleClass="field-label"/>
                <PasswordField fx:id="passwordField" promptText="Введите пароль" styleClass="login-field"/>
            </VBox>

            <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

            <Button fx:id="loginButton" text="Войти" maxWidth="Infinity"
                    onAction="#onLogin" styleClass="btn-primary"
                    style="-fx-padding: 12; -fx-font-size: 14px; -fx-cursor: hand;"/>
        </VBox>
    </VBox>
</StackPane>
