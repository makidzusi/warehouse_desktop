<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.openjfx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.warehouse.controller.CategoryController"
      spacing="16">
    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Категории" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="Добавить категорию" onAction="#onAdd" styleClass="btn-primary"/>
    </HBox>

    <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colName" text="Название" prefWidth="220"/>
            <TableColumn fx:id="colDescription" text="Описание" prefWidth="350"/>
            <TableColumn fx:id="colActions" text="Действия" prefWidth="160"/>
        </columns>
        <placeholder><Label text="Нет категорий. Добавьте первую."/></placeholder>
    </TableView>
</VBox>
