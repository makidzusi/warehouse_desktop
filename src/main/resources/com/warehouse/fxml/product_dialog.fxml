<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<DialogPane xmlns="http://javafx.openjfx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.warehouse.controller.ProductDialogController"
            prefWidth="480">

    <stylesheets>
        <String fx:value="/com/warehouse/css/styles.css"/>
    </stylesheets>

    <headerText>Товар</headerText>

    <content>
        <GridPane hgap="12" vgap="12">
            <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

            <Label text="Наименование *" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="nameField" promptText="Введите наименование"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="280"/>

            <Label text="Артикул (SKU) *" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <TextField fx:id="skuField" promptText="Например: SKU-001"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Категория" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <ComboBox fx:id="categoryCombo" prefWidth="280"
                      GridPane.columnIndex="1" GridPane.rowIndex="2"/>

            <Label text="Цена *" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <TextField fx:id="priceField" promptText="0.00"
                       GridPane.columnIndex="1" GridPane.rowIndex="3"/>

            <Label text="Единица измерения" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
            <ComboBox fx:id="unitCombo" prefWidth="280"
                      GridPane.columnIndex="1" GridPane.rowIndex="4"/>

            <Label text="Количество" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
            <Spinner fx:id="quantitySpinner" min="0" max="999999" initialValue="0"
                     GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="120"/>

            <Label text="Минимальный остаток" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <Spinner fx:id="minQtySpinner" min="0" max="999999" initialValue="0"
                     GridPane.columnIndex="1" GridPane.rowIndex="6" prefWidth="120"/>

            <Label text="Описание" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
            <TextArea fx:id="descriptionArea" prefRowCount="3" prefWidth="280" wrapText="true"
                      GridPane.columnIndex="1" GridPane.rowIndex="7"/>
        </GridPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="OK"/>
        <ButtonType fx:constant="CANCEL"/>
    </buttonTypes>
</DialogPane>
